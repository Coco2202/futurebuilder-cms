{
  "kind": "collectionType",
  "collectionName": "content_items",
  "info": {
    "singularName": "content-item",
    "pluralName": "content-items",
    "displayName": "content_item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "enum": ["video", "podcast", "pdf"]
    },
    "description": {
      "type": "text"
    },
    "sourceUrl": {
      "type": "string",
      "required": true
    },
    "durationMinutes": {
      "type": "decimal"
    },
    "scope": {
      "type": "enumeration",
      "required": true,
      "enum": ["core", "swst", "swsc"]
    },
    "accessLevel": {
      "type": "enumeration",
      "required": true,
      "default": "public",
      "enum": ["public", "organization_only"]
    },
    "topic": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::topic.topic",
      "inversedBy": "content_items"
    },
    "organization": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization.organization",
      "inversedBy": "content_items"
    },
    "difficultyLevel": {
      "type": "enumeration",
      "enum": ["foundation", "execution", "optimisation"]
    },
    "priority": {
      "type": "enumeration",
      "default": "medium",
      "enum": ["low", "medium", "high", "essential"]
    },
    "personaTags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::persona-tag.persona-tag"
    },
    "stageTags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::stage-tag.stage-tag"
    },
    "goalTags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::goal-tag.goal-tag"
    },
    "painPointTags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::topic-tag.topic-tag"
    },
    "customTags": {
      "type": "text"
    }
  }
}
