{
  "kind": "collectionType",
  "collectionName": "content_items",
  "info": {
    "singularName": "content-item",
    "pluralName": "content-items",
    "displayName": "content_item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "enum": ["video", "podcast", "pdf"]
    },
    "description": {
      "type": "text"
    },
    "sourceUrl": {
      "type": "string",
      "required": true
    },
    "durationMinutes": {
      "type": "decimal"
    },
    "scope": {
      "type": "enumeration",
      "required": true,
      "enum": ["core", "swst", "swsc"]
    },
    "accessLevel": {
      "type": "enumeration",
      "required": true,
      "default": "public",
      "enum": ["public", "organization_only"]
    },
    "topics": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::topic.topic",
      "inversedBy": "content_items"
    },
    "organizations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::organization.organization",
      "inversedBy": "content_items"
    },
    "difficultyLevel": {
      "type": "enumeration",
      "enum": ["foundation", "execution", "optimisation"]
    },
    "priority": {
      "type": "enumeration",
      "default": "medium",
      "enum": ["low", "medium", "high", "essential"]
    },
    "personaTags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::persona-tag.persona-tag"
    },
    "stageTags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::stage-tag.stage-tag"
    },
    "goalTags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::goal-tag.goal-tag"
    },
    "painPointTags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::topic-tag.topic-tag"
    },
    "customTags": {
      "type": "text"
    },
    "learningStage": {
      "type": "enumeration",
      "enum": ["beginner", "advanced", "pro"]
    },
    "sourcePlatform": {
      "type": "enumeration",
      "enum": ["youtube", "spotify"]
    },
    "sourceChannel": {
      "type": "string"
    },
    "sourceUploadDate": {
      "type": "date"
    },
    "sourceChecksum": {
      "type": "string"
    },
    "importStatus": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "ready",
        "needs_review",
        "needs_url_verify",
        "needs_url",
        "broken_url",
        "imported",
        "blocked"
      ]
    },
    "confidence": {
      "type": "integer",
      "min": 0,
      "max": 100
    },
    "tagReason": {
      "type": "text"
    },
    "needsReview": {
      "type": "boolean",
      "default": false
    },
    "reviewStatus": {
      "type": "enumeration",
      "default": "draft",
      "enum": [
        "draft",
        "review_required",
        "manual_review",
        "approved",
        "rejected",
        "unsupported_source"
      ]
    },
    "humanNotes": {
      "type": "text"
    },
    "importedAt": {
      "type": "datetime"
    },
    "importBatchId": {
      "type": "string"
    }
  }
}
