{
  "kind": "collectionType",
  "collectionName": "content_items",
  "info": {
    "singularName": "content-item",
    "pluralName": "content-items",
    "displayName": "Content Item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "video",
        "podcast",
        "pdf"
      ]
    },
    "description": {
      "type": "text"
    },
    "sourceUrl": {
      "type": "string",
      "required": true
    },
    "durationMinutes": {
      "type": "decimal"
    },
    "scope": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "core",
        "swst",
        "swsc"
      ]
    },
    "accessLevel": {
      "type": "enumeration",
      "required": true,
      "default": "public",
      "enum": [
        "public",
        "organization_only"
      ]
    },
    "topics": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::topic.topic",
      "inversedBy": "content_items"
    },
    "organizations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::organization.organization",
      "inversedBy": "content_items"
    },
    "playlistLevel": {
      "type": "enumeration",
      "enum": [
        "foundation",
        "execution",
        "optimisation"
      ]
    },
    "editorialPriority": {
      "type": "enumeration",
      "default": "medium",
      "enum": [
        "low",
        "medium",
        "high",
        "essential"
      ]
    },
    "builderTypeTag": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::persona-tag.persona-tag"
    },
    "startingPoint": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::stage-tag.stage-tag"
    },
    "goalTag": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::goal-tag.goal-tag"
    },
    "topicTag": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::topic-tag.topic-tag"
    },
    "customTags": {
      "type": "text"
    },
    "learningStage": {
      "type": "enumeration",
      "enum": [
        "beginner",
        "advanced",
        "pro"
      ]
    },
    "sourcePlatform": {
      "type": "enumeration",
      "enum": [
        "youtube",
        "spotify"
      ]
    },
    "sourceChannel": {
      "type": "string"
    },
    "sourceUploadDate": {
      "type": "date"
    },
    "sourceChecksum": {
      "type": "string"
    },
    "importStatus": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "ready",
        "needs_review",
        "needs_url_verify",
        "needs_url",
        "broken_url",
        "imported",
        "blocked"
      ]
    },
    "confidence": {
      "type": "integer",
      "min": 0,
      "max": 100
    },
    "tagReason": {
      "type": "text"
    },
    "needsReview": {
      "type": "boolean",
      "default": false
    },
    "reviewStatus": {
      "type": "enumeration",
      "default": "draft",
      "enum": [
        "draft",
        "review_required",
        "manual_review",
        "approved",
        "rejected",
        "unsupported_source"
      ]
    },
    "humanNotes": {
      "type": "text"
    },
    "importedAt": {
      "type": "datetime"
    },
    "importBatchId": {
      "type": "string"
    }
  }
}
