{
  "kind": "collectionType",
  "collectionName": "member_profiles",
  "info": {
    "singularName": "member-profile",
    "pluralName": "member-profiles",
    "displayName": "Member profile (mirror)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "backendUserId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "email": {
      "type": "email"
    },
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "termsAccepted": {
      "type": "boolean",
      "default": false
    },
    "termsVersion": {
      "type": "string"
    },
    "persona": {
      "type": "string"
    },
    "ecosystem": {
      "type": "string"
    },
    "stage": {
      "type": "string"
    },
    "goalPrimary": {
      "type": "string"
    },
    "toolsNotes": {
      "type": "text"
    },
    "playlistLevel": {
      "type": "string"
    },
    "organizationSlugs": {
      "type": "json"
    },
    "lastSyncedAt": {
      "type": "datetime"
    }
  }
}
