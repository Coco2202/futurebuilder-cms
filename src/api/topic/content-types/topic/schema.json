{
  "kind": "collectionType",
  "collectionName": "topics",
  "info": {
    "singularName": "topic",
    "pluralName": "topics",
    "displayName": "topic"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "text",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "accessLevel": {
      "type": "enumeration",
      "required": true,
      "default": "public",
      "enum": [
        "public",
        "organization_only"
      ]
    },
    "organization": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization.organization",
      "inversedBy": "topics"
    },
    "scope": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "core",
        "swst",
        "swsc"
      ]
    },
    "content_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::content-item.content-item",
      "mappedBy": "topic"
    },
    "orderIndex": {
      "type": "integer",
      "required": true
    }
  }
}
